# Ethereum Node Providers (WSS required for Mempool)
ETH_WSS_URL=wss://mainnet.infura.io/ws/v3/YOUR_INFURA_KEY
ETH_HTTP_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY

# Wallet for execution
PRIVATE_KEY=your_private_key_here
PUBLIC_ADDRESS=your_public_address_here

# Database
DATABASE_URL=sqlite:///mev_bot.db

# LLM integration (Ollama)
OLLAMA_HOST=http://localhost:11434
